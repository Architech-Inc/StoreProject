@page
@model StoreUI.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard - Store Management";
}

<section class="dashboard-shell">
    <div class="dashboard-hero glass-panel mb-4">
        <div>
            <h1 class="dashboard-title">Store Operations Hub</h1>
            <p class="dashboard-subtitle mb-0">Manage inventory, customers, employees, invoices, and records from one workspace.</p>
        </div>
        <div class="hero-badge">Live Workspace</div>
    </div>

    <div class="row g-3 g-lg-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card app-card h-100 text-center">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Items</h5>
                    <p class="card-text">Manage product inventory</p>
                    <a href="/items" class="btn app-btn-primary mt-auto">View Items</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card app-card h-100 text-center">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Customers</h5>
                    <p class="card-text">Manage customer records</p>
                    <a href="/customers" class="btn app-btn-primary mt-auto">View Customers</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card app-card h-100 text-center">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Employees</h5>
                    <p class="card-text">Manage employee information</p>
                    <a href="/employees" class="btn app-btn-primary mt-auto">View Employees</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card app-card h-100 text-center">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Invoices</h5>
                    <p class="card-text">View sales transactions</p>
                    <a href="/invoices" class="btn app-btn-primary mt-auto">View Invoices</a>
                </div>
            </div>
        </div>
    </div>
</section>
