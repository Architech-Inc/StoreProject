<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Store Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="ambient-bg" aria-hidden="true"></div>

    <nav class="navbar navbar-expand-lg app-navbar sticky-top">
        <div class="container-fluid px-3 px-lg-4">
            <a class="navbar-brand app-brand" href="/">ClexAn Store</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item"><a class="nav-link app-nav-link" href="/dashboard">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link app-nav-link" href="/items">Items</a></li>
                        <li class="nav-item"><a class="nav-link app-nav-link" href="/customers">Customers</a></li>
                        <li class="nav-item"><a class="nav-link app-nav-link" href="/employees">Employees</a></li>
                        <li class="nav-item">
                            <form method="post" action="/logout" style="display:inline;">
                                <button type="submit" class="btn btn-sm app-btn-danger">Logout</button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-3 px-lg-4">
        <main role="main" class="app-main py-3 py-lg-4">
            @RenderBody()
        </main>

        <footer class="app-footer mt-3 mt-lg-4 py-3">
            <div class="text-center">
                <span>&copy; 2026 ClexAn Store Management System</span>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
