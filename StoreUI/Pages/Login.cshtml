@page
@model StoreUI.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClexAn Login</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-page">
    <div id="welcomeView">
        <div class="viewNameSpace">
            <h2 class="nameSpace"><sign class="atSign">@@</sign>ClexAn</h2>
        </div>

        <div id="avatarBox">
            <img src="~/images/admin.png" alt="avatar" id="avatar" />
            <span id="avatarText" class="avatarText">Admin</span>
        </div>

        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <p class="auth-error">@Model.ErrorMessage</p>
        }

        <div class="formArea">
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="formSection">
                    <label for="Username">Username</label>
                    <input title="username" tabindex="0" type="text" asp-for="Username" id="inputUserName" autocomplete="username" />
                    <span id="inputError-0"></span>
                </div>
                <div class="formSection">
                    <label for="Password">Password</label>
                    <input title="password" type="password" asp-for="Password" id="inputPassword" autocomplete="current-password" />
                    <span id="inputError-1"></span>
                </div>
                <div class="formSection LDiv">
                    <button type="submit" id="login">LOGIN</button>
                </div>
                <p class="forgot_pass">Forgot password? Contact <a href="#">God Admin</a></p>
            </form>
        </div>
    </div>
</div>
</body>
</html>
