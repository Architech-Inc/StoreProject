<div class="stackPanel" id="stackPanel">
    <div class="panelHeader">
        <div class="exitPanel" id="exitPanel">
            <img alt="avatar" src="@(LibraryHelper.ContentPath)images/exit.png" class="exit" />
        </div>
        <div class="infoAdmin">
            <img src="@(LibraryHelper.ContentPath)images/admin.png" alt="" class="adminPic">
            <div class="infoCover" style="display: flex;
            flex-direction: column; position: absolute; right: 8px; top: 20vh;">
                <span class="adminNameLabel">
                    Admin:
                </span>
                <span class="AdminName">Clarks</span>
            </div>
        </div>
    </div>
    <ul class="panel_list">
        <li id='clickId_rec' class="li_selected">Records</li>
        <li id='clickId_dash'>Dashboard</li>
        <li id='clickId_an'>Analytics</li>
        <li id='clickId_bs'>Business Stats</li>
        <li id='clickId_db'>DB Operations</li>
        <li id='clickId_set'>Settings</li>
        <li id='clickId_log'>
            Logout
            <img src="@(LibraryHelper.ContentPath)images/logout.png" alt="" class="lgIcon">
        </li>

    </ul>
    <div class="stackInfo" style="padding: 2%;">
        <img src="@(LibraryHelper.ContentPath)images/clarkstore.png" alt="">
        <div class="stInfo">
            <h3 class="thick">ClexAn Foods</h3>
            <span>Publisher: Architech Inc.</span>
        </div>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
