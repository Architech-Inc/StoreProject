@page
@model StoreUI.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClexAn Login</title>
    <link rel="icon" type="image/png" href="~/images/clarkstore.png" asp-append-version="true" />
    <link rel="shortcut icon" type="image/png" href="~/images/clarkstore.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-page">
    <div id="welcomeView">
        <div class="viewNameSpace">
            @* <h2 class="nameSpace"><sign class="atSign">@@</sign>ClexAn</h2> *@
            <img src="~/images/clarkstore.png" alt="logo" class="ns-image">
        </div>

        <div id="avatarBox">
            <img src="~/images/admin.png" alt="avatar" id="avatar" />
            <span id="avatarText" class="avatarText">Admin</span>
        </div>

        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <p class="auth-error">@Model.ErrorMessage</p>
        }

        <div class="formArea">
            <form method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                <div class="formSection">
                    <label for="inputUserName">Username</label>
                    <input title="username" tabindex="0" type="text" asp-for="Username" id="inputUserName"
                           autocomplete="username" minlength="3" maxlength="100" />
                    <span id="inputError-0"></span>
                </div>
                <div class="formSection">
                    <label for="inputPassword">Password</label>
                    <input title="password" type="password" asp-for="Password" id="inputPassword"
                           autocomplete="current-password" minlength="8" maxlength="128" />
                    <span id="inputError-1"></span>
                </div>
                <div class="formSection LDiv">
                    <button type="submit" id="login">Login</button>
                </div>
                <p class="forgot_pass">Forgot password? Contact <a href="mailto:admin@clexan.local">God Admin</a></p>
            </form>
        </div>
    </div>
</div>
<script>
    (function () {
        const form = document.getElementById('loginForm');
        const usernameInput = document.getElementById('inputUserName');
        const passwordInput = document.getElementById('inputPassword');
        const usernameErr = document.getElementById('inputError-0');
        const passwordErr = document.getElementById('inputError-1');

        function validateUsername() {
            const val = usernameInput.value.trim();
            if (!val) {
                usernameErr.textContent = 'Username is required.';
                return false;
            }
            if (val.length < 3) {
                usernameErr.textContent = 'Username must be at least 3 characters.';
                return false;
            }
            usernameErr.textContent = '';
            return true;
        }

        function validatePassword() {
            const val = passwordInput.value;
            if (!val) {
                passwordErr.textContent = 'Password is required.';
                return false;
            }
            if (val.length < 8) {
                passwordErr.textContent = 'Password must be at least 8 characters.';
                return false;
            }
            passwordErr.textContent = '';
            return true;
        }

        usernameInput.addEventListener('input', validateUsername);
        passwordInput.addEventListener('input', validatePassword);

        form.addEventListener('submit', function (e) {
            const u = validateUsername();
            const p = validatePassword();
            if (!u || !p) {
                e.preventDefault();
            }
        });
    })();
</script>
    </div>
</div>
</body>
</html>
