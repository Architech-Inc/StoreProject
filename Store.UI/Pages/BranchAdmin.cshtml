@page
@model StoreUI.Pages.BranchAdminModel
@{
    ViewData["Title"] = "Branch Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/operations.css" asp-append-version="true" />
}

<div class="ops-page">
    <header>
        <h1>Branch Management</h1>
        <p>Create branches and assign users to branches with specific roles.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status">@Model.StatusMessage</div>
    }

    @* ── Branches ── *@
    <section class="card" id="branches">
        <h2>Branches</h2>

        <form method="post" asp-page-handler="UpsertBranch" class="form-grid">
            <input type="hidden" asp-for="EditBranchId" />
            <div class="form-row">
                <label asp-for="BranchName">Name</label>
                <input asp-for="BranchName" class="input" required maxlength="120" />
            </div>
            <div class="form-row">
                <label asp-for="BranchCode">Code</label>
                <input asp-for="BranchCode" class="input" required maxlength="20" />
            </div>
            <div class="form-row">
                <label asp-for="BranchAddress">Address</label>
                <input asp-for="BranchAddress" class="input" maxlength="300" />
            </div>
            <div class="form-row">
                <label asp-for="BranchIsActive">Active</label>
                <input asp-for="BranchIsActive" type="checkbox" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Branch</button>
            </div>
        </form>

        @if (Model.Branches.Count > 0)
        {
            <table class="data-table mt-4">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Address</th>
                        <th>Active</th>
                        <th>Edit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Branches)
                    {
                        <tr>
                            <td>@b.BranchId</td>
                            <td>@b.Code</td>
                            <td>@b.Name</td>
                            <td>@(b.Address ?? "—")</td>
                            <td>
                                @if (b.IsActive)
                                {
                                    <span class="badge badge-green">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-grey">Inactive</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm"
                                        onclick="fillBranchForm(@b.BranchId, '@Html.Raw(Html.Encode(b.Code))', '@Html.Raw(Html.Encode(b.Name))', '@Html.Raw(Html.Encode(b.Address ?? ""))', @(b.IsActive ? "true" : "false"))">
                                    Edit
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No branches yet.</p>
        }
    </section>

    @* ── User-Branch-Role Assignments ── *@
    <section class="card" id="assignments">
        <h2>User Branch Assignments</h2>

        <form method="post" asp-page-handler="Assign" class="form-grid">
            <div class="form-row">
                <label asp-for="AssignUserId">User</label>
                <select asp-for="AssignUserId" class="input" required>
                    <option value="">— select user —</option>
                    @foreach (var u in Model.AllUsers)
                    {
                        <option value="@u.UserId">@u.Username</option>
                    }
                </select>
            </div>
            <div class="form-row">
                <label asp-for="AssignBranchId">Branch</label>
                <select asp-for="AssignBranchId" class="input" required>
                    <option value="">— select branch —</option>
                    @foreach (var b in Model.Branches)
                    {
                        <option value="@b.BranchId">@b.Name (@b.Code)</option>
                    }
                </select>
            </div>
            <div class="form-row">
                <label asp-for="AssignRoleId">Role</label>
                <select asp-for="AssignRoleId" class="input" required>
                    <option value="">— select role —</option>
                    @foreach (var r in Model.RoleMatrix)
                    {
                        <option value="@r.RoleId">@r.RoleName</option>
                    }
                </select>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Assign</button>
            </div>
        </form>

        @if (Model.Assignments.Count > 0)
        {
            <table class="data-table mt-4">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Branch</th>
                        <th>Role</th>
                        <th>Revoke</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Assignments)
                    {
                        <tr>
                            <td>@a.UserName</td>
                            <td>@a.BranchName</td>
                            <td>@a.RoleName</td>
                            <td>
                                <form method="post" asp-page-handler="Revoke" style="display:inline">
                                    <input type="hidden" name="assignmentId" value="@a.UserBranchRoleId" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Remove this assignment?')">
                                        Revoke
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No assignments yet.</p>
        }
    </section>
</div>

@section Scripts {
    <script>
        function fillBranchForm(id, code, name, address, isActive) {
            document.querySelector('[name="EditBranchId"]').value = id;
            document.querySelector('[name="BranchName"]').value = name;
            document.querySelector('[name="BranchCode"]').value = code;
            document.querySelector('[name="BranchAddress"]').value = address;
            document.querySelector('[name="BranchIsActive"]').checked = isActive;
            document.getElementById('branches').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
}
