@page
@model StoreUI.Pages.CampaignsModel
@{
    ViewData["Title"] = "Loyalty Campaigns";
    ViewData["ActivePage"] = "Campaigns";
}

@section Styles {
    <link rel="stylesheet" href="~/css/operations.css" asp-append-version="true" />
}

<div class="ops-page">
    <header>
        <h1>Loyalty Campaigns</h1>
        <p>Create and manage point multiplier and bonus campaigns for customer segments.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status @(Model.StatusMessage.StartsWith("Error") ? "error" : "ok")">
            @Model.StatusMessage
        </div>
    }

    <section class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <h2 style="margin:0;">Campaigns <small style="font-weight:400;color:var(--ops-subtle);">@Model.Campaigns.Count total</small></h2>
            <button type="button" onclick="openCreate()">+ New Campaign</button>
        </div>

        @if (!Model.Campaigns.Any())
        {
            <p style="color:var(--ops-subtle);padding:12px 0;">No campaigns created yet.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Target</th>
                            <th>Multiplier / Bonus</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var camp in Model.Campaigns)
                        {
                            <tr>
                                <td><strong>@camp.Name</strong>
                                    @if (camp.Description is not null)
                                    {
                                        <br /><small style="color:var(--ops-subtle);">@camp.Description</small>
                                    }
                                </td>
                                <td>@camp.CampaignType</td>
                                <td>@(camp.TargetSegment ?? "All")</td>
                                <td>
                                    @if (camp.CampaignType == "PointMultiplier")
                                    {
                                        <span>×@camp.MultiplierFactor</span>
                                    }
                                    else
                                    {
                                        <span>+@camp.BonusPoints pts</span>
                                    }
                                </td>
                                <td>@camp.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@camp.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (!camp.IsActive)
                                    {
                                        <span class="badge badge-gray">Inactive</span>
                                    }
                                    else if (camp.IsRunning)
                                    {
                                        <span class="badge badge-green">Live</span>
                                    }
                                    else if (camp.EndDate < DateTime.UtcNow)
                                    {
                                        <span class="badge badge-gray">Ended</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-blue">Scheduled</span>
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:4px;">
                                        <button type="button"
                                            onclick="openEdit(@camp.LoyaltyCampaignId,'@Html.Raw(camp.Name.Replace("'","\\'"))','@Html.Raw((camp.Description ?? "").Replace("'","\\'"))','@camp.CampaignType','@(camp.TargetSegment ?? "")','@camp.MultiplierFactor','@camp.BonusPoints','@camp.StartDate.ToString("yyyy-MM-dd")','@camp.EndDate.ToString("yyyy-MM-dd")','@camp.IsActive.ToString().ToLower()')">Edit</button>
                                        <form method="post" asp-page-handler="Delete" style="margin:0;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="campaignId" value="@camp.LoyaltyCampaignId" />
                                            <button type="submit" class="danger" onclick="return confirm('Delete @(camp.Name.Replace("'","\\'"))?')">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

<!-- ── Create Campaign Modal ───────────────────────────────── -->
<div class="modal-overlay" id="campaignModal" hidden>
    <div class="modal" role="dialog" aria-labelledby="campModalTitle" aria-modal="true">
        <div class="modal-head">
            <h3 id="campModalTitle">New Campaign</h3>
            <button type="button" class="btn-close" onclick="closeCreate()" aria-label="Close">×</button>
        </div>

        <form method="post" asp-page-handler="Create">
            @Html.AntiForgeryToken()

            <label for="name">Campaign Name *</label>
            <input asp-for="Name" id="name" required />

            <label for="description">Description</label>
            <textarea asp-for="Description" id="description" rows="2"></textarea>

            <label for="campaignType">Campaign Type</label>
            <select asp-for="CampaignType" id="campaignType" onchange="toggleCampaignFields(this,'')">
                <option value="PointMultiplier">Point Multiplier</option>
                <option value="FixedBonusPoints">Fixed Bonus Points</option>
            </select>

            <label for="targetSegment">Target Segment</label>
            <select asp-for="TargetSegment" id="targetSegment">
                <option value="">All Segments</option>
                <option value="Standard">Standard</option>
                <option value="Wholesale">Wholesale</option>
                <option value="Vip">VIP</option>
            </select>

            <div id="multiplierField">
                <label for="multiplierFactor">Multiplier Factor (e.g. 2.0 = double points)</label>
                <input asp-for="MultiplierFactor" id="multiplierFactor" type="number" step="0.01" min="0.01" max="100" />
            </div>

            <div id="bonusField" hidden>
                <label for="bonusPoints">Bonus Points</label>
                <input asp-for="BonusPoints" id="bonusPoints" type="number" min="0" max="100000" />
            </div>

            <label for="startDate">Start Date *</label>
            <input asp-for="StartDate" id="startDate" type="date" required />

            <label for="endDate">End Date *</label>
            <input asp-for="EndDate" id="endDate" type="date" required />

            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                <input asp-for="IsActive" type="checkbox" />
                Active
            </label>

            <div style="display:flex;gap:8px;margin-top:8px;">
                <button type="submit">Create Campaign</button>
                <button type="button" class="danger" onclick="closeCreate()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Edit Campaign Modal ────────────────────────────────── -->
<div class="modal-overlay" id="editCampaignModal" hidden>
    <div class="modal" role="dialog" aria-labelledby="editCampModalTitle" aria-modal="true">
        <div class="modal-head">
            <h3 id="editCampModalTitle">Edit Campaign</h3>
            <button type="button" class="btn-close" onclick="closeEdit()" aria-label="Close">×</button>
        </div>

        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EditCampaignId" id="editCampaignId" />

            <label for="editName">Campaign Name *</label>
            <input asp-for="EditName" id="editName" required />

            <label for="editDescription">Description</label>
            <textarea asp-for="EditDescription" id="editDescription" rows="2"></textarea>

            <label for="editCampaignType">Campaign Type</label>
            <select asp-for="EditCampaignType" id="editCampaignType" onchange="toggleCampaignFields(this,'edit')">
                <option value="PointMultiplier">Point Multiplier</option>
                <option value="FixedBonusPoints">Fixed Bonus Points</option>
            </select>

            <label for="editTargetSegment">Target Segment</label>
            <select asp-for="EditTargetSegment" id="editTargetSegment">
                <option value="">All Segments</option>
                <option value="Standard">Standard</option>
                <option value="Wholesale">Wholesale</option>
                <option value="Vip">VIP</option>
            </select>

            <div id="editMultiplierField">
                <label for="editMultiplierFactor">Multiplier Factor</label>
                <input asp-for="EditMultiplierFactor" id="editMultiplierFactor" type="number" step="0.01" min="0.01" max="100" />
            </div>

            <div id="editBonusField" hidden>
                <label for="editBonusPoints">Bonus Points</label>
                <input asp-for="EditBonusPoints" id="editBonusPoints" type="number" min="0" max="100000" />
            </div>

            <label for="editStartDate">Start Date *</label>
            <input asp-for="EditStartDate" id="editStartDate" type="date" required />

            <label for="editEndDate">End Date *</label>
            <input asp-for="EditEndDate" id="editEndDate" type="date" required />

            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                <input asp-for="EditIsActive" id="editIsActive" type="checkbox" />
                Active
            </label>

            <div style="display:flex;gap:8px;margin-top:8px;">
                <button type="submit">Save Changes</button>
                <button type="button" onclick="closeEdit()">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
const createModal = document.getElementById('campaignModal');
const editModal   = document.getElementById('editCampaignModal');

function openCreate() {
    createModal.removeAttribute('hidden');
    document.getElementById('name').focus();
}
function closeCreate() { createModal.setAttribute('hidden', ''); }

function openEdit(id, name, description, type, segment, multiplier, bonus, startDate, endDate, isActive) {
    document.getElementById('editCampaignId').value  = id;
    document.getElementById('editName').value        = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editCampaignType').value    = type;
    document.getElementById('editTargetSegment').value   = segment;
    document.getElementById('editMultiplierFactor').value = multiplier;
    document.getElementById('editBonusPoints').value      = bonus;
    document.getElementById('editStartDate').value = startDate;
    document.getElementById('editEndDate').value   = endDate;
    document.getElementById('editIsActive').checked = isActive === 'true';
    toggleCampaignFields(document.getElementById('editCampaignType'), 'edit');
    editModal.removeAttribute('hidden');
    document.getElementById('editName').focus();
}
function closeEdit() { editModal.setAttribute('hidden', ''); }

function toggleCampaignFields(sel, prefix) {
    const p = prefix ? prefix.charAt(0).toUpperCase() + prefix.slice(1) : '';
    const multField  = document.getElementById(prefix ? 'editMultiplierField' : 'multiplierField');
    const bonusField = document.getElementById(prefix ? 'editBonusField' : 'bonusField');
    if (sel.value === 'FixedBonusPoints') {
        multField.setAttribute('hidden', '');
        bonusField.removeAttribute('hidden');
    } else {
        multField.removeAttribute('hidden');
        bonusField.setAttribute('hidden', '');
    }
}

[createModal, editModal].forEach(m => {
    m.addEventListener('click', e => { if (e.target === m) { closeCreate(); closeEdit(); } });
});
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeCreate(); closeEdit(); }
});
</script>
}
