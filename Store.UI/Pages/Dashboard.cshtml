@page
@model StoreUI.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<header class="topbar">
    <button type="button" class="menu-toggle" id="menuToggle" aria-expanded="false" aria-controls="appSidebar">Menu</button>
    <div>
        <h1>Store Dashboard</h1>
        <p>Realtime summary of sales, customers, and inventory health.</p>
    </div>
</header>

        @if (Model.HasLoadError)
        {
            <div class="status-banner error" role="alert">
                <strong>Data Sync Issue:</strong> @Model.LoadErrorMessage
            </div>
        }
        else
        {
            <div class="status-banner ok" role="status" aria-live="polite">
                Dashboard loaded successfully.
            </div>
        }

        <section class="metric-grid" id="overview" aria-label="Key metrics">
            <article class="metric-card">
                <h2>Total Items</h2>
                <p>@Model.TotalItems</p>
                <span class="metric-meta">Available products in catalog</span>
            </article>
            <article class="metric-card">
                <h2>Total Customers</h2>
                <p>@Model.TotalCustomers</p>
                <span class="metric-meta">Registered customer records</span>
            </article>
            <article class="metric-card">
                <h2>Total Invoices</h2>
                <p>@Model.TotalInvoices</p>
                <span class="metric-meta">Invoices processed in system</span>
            </article>
            <article class="metric-card attention">
                <h2>Low Stock Alerts</h2>
                <p>@Model.LowStockItems</p>
                <span class="metric-meta">Items below reorder threshold</span>
            </article>
        </section>

        <section class="panel-grid">
            <article class="panel" id="invoices">
                <header>
                    <h2>Recent Invoices</h2>
                    <span>@Model.RecentInvoices.Count records</span>
                </header>

                @if (!Model.RecentInvoices.Any())
                {
                    <p class="empty-state" role="status">No invoice data available.</p>
                }
                else
                {
                    <div class="table-wrap" role="region" aria-label="Recent invoices table">
                        <table>
                            <thead>
                                <tr>
                                    <th scope="col">Invoice ID</th>
                                    <th scope="col">Customer</th>
                                    <th scope="col">Amount</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invoice in Model.RecentInvoices)
                                {
                                    <tr>
                                        <td>@invoice.InvoiceId.ToString()[..8]</td>
                                        <td>@(string.IsNullOrWhiteSpace(invoice.CustomerName) ? "Walk-in" : invoice.CustomerName)</td>
                                        <td>@invoice.TotalAmount.ToString("N0") XAF</td>
                                        <td>
                                            <span class="pill @(invoice.IsPaid ? "paid" : "unpaid")">
                                                @(invoice.IsPaid ? "Paid" : "Pending")
                                            </span>
                                        </td>
                                        <td>@invoice.DateCreated.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </article>

            <article class="panel" id="inventory">
                <header>
                    <h2>Low Stock Watchlist</h2>
                    <span>@Model.LowStockList.Count items</span>
                </header>

                @if (!Model.LowStockList.Any())
                {
                    <p class="empty-state" role="status">No low-stock items detected.</p>
                }
                else
                {
                    <ul class="stock-list">
                        @foreach (var item in Model.LowStockList)
                        {
                            <li>
                                <div>
                                    <strong>@item.Name</strong>
                                    <small>@(item.CategoryName ?? "Uncategorized")</small>
                                </div>
                                <span class="stock-level">@item.InStock in stock</span>
                            </li>
                        }
                    </ul>
                }
            </article>
        </section>

        <section class="panel" id="health" aria-label="Operational shortcuts">
            <header>
                <h2>Quick Actions</h2>
                <span>Productivity shortcuts</span>
            </header>
            <div class="action-row">
                <a class="action-link" href="/Pos">Open POS Terminal</a>
                <a class="action-link" href="/Catalog">Item Catalog</a>
                <a class="action-link" href="/Customers">Customers</a>
                <a class="action-link" href="/Invoices">Invoices</a>
                <a class="action-link" href="/Orders">Purchase Orders</a>
                <a class="action-link" href="/Suppliers">Suppliers</a>
                <a class="action-link" href="/Loyalty">Customer Loyalty</a>
                @if (Model.CanInventoryRead)
                {
                    <a class="action-link" href="/Employees">Employees</a>
                    <a class="action-link" href="/InventoryOps">Inventory Operations</a>
                    <a class="action-link" href="/AuditLog">Audit Log</a>
                }
                @if (Model.CanPricingRead)
                {
                    <a class="action-link" href="/PricingOps">Pricing & Promotions</a>
                    <a class="action-link" href="/PromotionEffectiveness">Promo Effectiveness</a>
                }
                @if (Model.CanCashRead || Model.CanReportsRead)
                {
                    <a class="action-link" href="/CashReports">Cash & Reports</a>
                    <a class="action-link" href="/Reconciliation">Day-End Reconciliation</a>
                }
                @if (Model.CanPaymentsRead)
                {
                    <a class="action-link" href="/Payments">Payments</a>
                }
                @if (Model.CanAdminBranches)
                {
                    <a class="action-link" href="/BranchAdmin">Branch Admin</a>
                    <a class="action-link" href="/BranchDashboard">Branch Dashboard</a>
                }
                @if (Model.CanAdminRoleMatrix)
                {
                    <a class="action-link" href="/Users">Users</a>
                    <a class="action-link" href="/Lookup">Lookups</a>
                    <a class="action-link" href="/RoleMatrix">Role Matrix</a>
                }
                <a class="action-link" href="/Login">Switch User</a>
            </div>
        </section>
