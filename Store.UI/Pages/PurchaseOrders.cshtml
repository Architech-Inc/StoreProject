@page
@model StoreUI.Pages.PurchaseOrdersModel
@using Store.Models.Enums
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Purchase Orders";
    ViewData["ActivePage"] = "PurchaseOrders";
}

@if (TempData["StatusMessage"] is string msg)
{
    var isError = msg.StartsWith("Error:", StringComparison.OrdinalIgnoreCase);
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Purchase Orders</h4>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createPoModal">
        + New Purchase Order
    </button>
</div>

<!-- Filter bar -->
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">All Statuses</option>
            @foreach (var s in Model.Statuses)
            {
                <option value="@s" selected="@(Model.FilterStatus == s.ToString())">@s</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-secondary btn-sm" type="submit">Filter</button>
    </div>
</form>

<!-- PO List -->
<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Reference</th>
                <th>Supplier</th>
                <th>Branch</th>
                <th>Status</th>
                <th>Expected Delivery</th>
                <th>Requested By</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var po in Model.PurchaseOrders)
            {
                <tr>
                    <td>@po.PurchaseOrderId</td>
                    <td>@(po.ReferenceNumber ?? "—")</td>
                    <td>@po.SupplierName</td>
                    <td>@(po.BranchName ?? "—")</td>
                    <td>
                        <span class="badge @(po.Status switch {
                            "Draft" => "bg-secondary",
                            "Submitted" => "bg-info text-dark",
                            "Approved" => "bg-primary",
                            "PartiallyReceived" => "bg-warning text-dark",
                            "Received" => "bg-success",
                            "Cancelled" => "bg-danger",
                            _ => "bg-secondary" })">
                            @po.Status
                        </span>
                    </td>
                    <td>@(po.ExpectedDeliveryDate?.ToString("dd MMM yyyy") ?? "—")</td>
                    <td>@po.RequestedByUser</td>
                    <td>@po.DateCreated.ToString("dd MMM yyyy")</td>
                    <td>
                        <div class="d-flex gap-1">
                            @if (po.Status == "Draft")
                            {
                                <form method="post" asp-page-handler="Submit">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ActionPurchaseOrderId" value="@po.PurchaseOrderId" />
                                    <button class="btn btn-outline-info btn-sm" type="submit">Submit</button>
                                </form>
                                <form method="post" asp-page-handler="Cancel">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ActionPurchaseOrderId" value="@po.PurchaseOrderId" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit"
                                            onclick="return confirm('Cancel this PO?')">Cancel</button>
                                </form>
                            }
                            @if (po.Status == "Submitted")
                            {
                                <form method="post" asp-page-handler="Approve">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ActionPurchaseOrderId" value="@po.PurchaseOrderId" />
                                    <button class="btn btn-outline-primary btn-sm" type="submit">Approve</button>
                                </form>
                                <form method="post" asp-page-handler="Cancel">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ActionPurchaseOrderId" value="@po.PurchaseOrderId" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit"
                                            onclick="return confirm('Cancel this PO?')">Cancel</button>
                                </form>
                            }
                            @if (po.Status == "Approved" || po.Status == "PartiallyReceived")
                            {
                                <button class="btn btn-outline-success btn-sm"
                                        data-bs-toggle="modal" data-bs-target="#receiveModal"
                                        data-po-id="@po.PurchaseOrderId"
                                        data-po-items="@System.Text.Json.JsonSerializer.Serialize(po.Items)">
                                    Receive
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.PurchaseOrders.Any())
            {
                <tr><td colspan="9" class="text-center text-muted py-3">No purchase orders found.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- ===== Create PO Modal ===== -->
<div class="modal fade" id="createPoModal" tabindex="-1" aria-labelledby="createPoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <form method="post" asp-page-handler="Create">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createPoModalLabel">New Purchase Order</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Supplier ID <span class="text-danger">*</span></label>
                            <input type="text" name="CreateSupplierId" class="form-control form-control-sm"
                                   placeholder="Supplier GUID" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Branch ID</label>
                            <input type="number" name="CreateBranchId" class="form-control form-control-sm"
                                   placeholder="Optional" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Reference Number</label>
                            <input type="text" name="CreateReferenceNumber" class="form-control form-control-sm"
                                   placeholder="e.g. PO-2024-001" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Expected Delivery</label>
                            <input type="date" name="CreateExpectedDelivery" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea name="CreateNotes" class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Line Items</strong>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="addLineBtn">+ Add Item</button>
                    </div>
                    <table class="table table-sm" id="lineItemsTable">
                        <thead class="table-light">
                            <tr>
                                <th>Item ID (GUID)</th>
                                <th>Qty</th>
                                <th>Unit Cost</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="lineItemsBody">
                            <tr>
                                <td><input type="text" name="CreateItemIds" class="form-control form-control-sm" placeholder="Item GUID" required /></td>
                                <td><input type="number" name="CreateQuantities" class="form-control form-control-sm" value="1" min="1" required /></td>
                                <td><input type="number" name="CreateUnitCosts" class="form-control form-control-sm" value="0.00" min="0" step="0.01" required /></td>
                                <td><button type="button" class="btn btn-outline-danger btn-sm remove-line-btn">✕</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Purchase Order</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ===== Receive Goods Modal ===== -->
<div class="modal fade" id="receiveModal" tabindex="-1" aria-labelledby="receiveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form method="post" asp-page-handler="Receive">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="receiveModalLabel">Receive Goods</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="ActionPurchaseOrderId" id="receivePoId" />
                    <table class="table table-sm" id="receiveItemsTable">
                        <thead class="table-light">
                            <tr>
                                <th>Item</th>
                                <th>Ordered</th>
                                <th>Already Received</th>
                                <th>Receiving Now</th>
                                <th><input type="hidden" class="hidden-id" /></th>
                            </tr>
                        </thead>
                        <tbody id="receiveItemsBody"></tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm Receipt</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
// Add line item row
document.getElementById('addLineBtn').addEventListener('click', function () {
    const tbody = document.getElementById('lineItemsBody');
    const row = document.createElement('tr');
    row.innerHTML = `
        <td><input type="text" name="CreateItemIds" class="form-control form-control-sm" placeholder="Item GUID" required /></td>
        <td><input type="number" name="CreateQuantities" class="form-control form-control-sm" value="1" min="1" required /></td>
        <td><input type="number" name="CreateUnitCosts" class="form-control form-control-sm" value="0.00" min="0" step="0.01" required /></td>
        <td><button type="button" class="btn btn-outline-danger btn-sm remove-line-btn">✕</button></td>`;
    tbody.appendChild(row);
});

document.addEventListener('click', function (e) {
    if (e.target.classList.contains('remove-line-btn')) {
        const tbody = document.getElementById('lineItemsBody');
        if (tbody.rows.length > 1) e.target.closest('tr').remove();
    }
});

// Receive modal population
const receiveModal = document.getElementById('receiveModal');
receiveModal.addEventListener('show.bs.modal', function (e) {
    const btn = e.relatedTarget;
    const poId = btn.getAttribute('data-po-id');
    const items = JSON.parse(btn.getAttribute('data-po-items'));

    document.getElementById('receivePoId').value = poId;
    const tbody = document.getElementById('receiveItemsBody');
    tbody.innerHTML = '';

    items.forEach(function (item) {
        const remaining = item.orderedQuantity - item.receivedQuantity;
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${item.itemName} <small class="text-muted">(${item.itemCode})</small></td>
            <td>${item.orderedQuantity}</td>
            <td>${item.receivedQuantity}</td>
            <td><input type="number" name="ReceiveQuantities" class="form-control form-control-sm"
                        value="${remaining}" min="0" max="${item.orderedQuantity}" /></td>
            <td><input type="hidden" name="ReceiveItemLineIds" value="${item.purchaseOrderItemId}" /></td>`;
        tbody.appendChild(row);
    });
});
</script>
}
