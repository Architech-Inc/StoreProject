@page
@model StoreUI.Pages.WastageModel
@{
    ViewData["Title"] = "Wastage Log";
    ViewData["ActivePage"] = "Wastage";
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/operations.css" asp-append-version="true" />
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Wastage Log</h1>
        <p class="page-subtitle text-muted">Record and track stock write-offs due to damage, expiry, theft, or spoilage.</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#recordModal">
        <i class="bi bi-plus-circle me-1"></i> Record Wastage
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filter Bar -->
<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="form-label mb-0 me-1">Type:</label>
            <select name="wastageType" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="">All Types</option>
                @foreach (var t in Model.WastageTypes)
                {
                    <option value="@t" selected="@(Model.FilterType == t.ToString())">@t</option>
                }
            </select>
        </form>
    </div>
</div>

<!-- Entries Table -->
<div class="card">
    <div class="card-body p-0">
        @if (!Model.Entries.Any())
        {
            <div class="empty-state text-center py-5">
                <i class="bi bi-trash3 fs-1 text-muted"></i>
                <p class="mt-2 text-muted">No wastage entries found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Item</th>
                            <th>Code</th>
                            <th>Type</th>
                            <th>Qty</th>
                            <th>Reference</th>
                            <th>Notes</th>
                            <th>Recorded By</th>
                            <th>Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.Entries)
                        {
                            <tr>
                                <td>@e.WastageEntryId</td>
                                <td>@e.ItemName</td>
                                <td><code>@e.ItemCode</code></td>
                                <td>
                                    <span class="badge bg-warning text-dark">@e.WastageType</span>
                                </td>
                                <td>@e.Quantity</td>
                                <td>@(e.ReferenceCode ?? "—")</td>
                                <td class="text-truncate" style="max-width:200px">@(e.Notes ?? "—")</td>
                                <td>@e.RecordedByUser</td>
                                <td>@e.DateCreated.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <form method="post" asp-page-handler="Delete"
                                          onsubmit="return confirm('Delete this wastage entry?')">
                                        <input type="hidden" name="DeleteEntryId" value="@e.WastageEntryId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Record Wastage Modal -->
<div class="modal fade" id="recordModal" tabindex="-1" aria-labelledby="recordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Record">
                <div class="modal-header">
                    <h5 class="modal-title" id="recordModalLabel">Record Wastage</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Item ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="RecordItemId" placeholder="Paste item GUID"
                               required pattern="[0-9a-fA-F\-]{36}" />
                        <div class="form-text">Enter the item's unique identifier (GUID).</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Wastage Type</label>
                        <select class="form-select" name="RecordWastageType">
                            @foreach (var t in Model.WastageTypes)
                            {
                                <option value="@((int)t)">@t</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantity <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" name="RecordQuantity" min="1" value="1" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reference Code</label>
                        <input type="text" class="form-control" name="RecordReferenceCode" maxlength="100"
                               placeholder="e.g. WASTE-2024-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" name="RecordNotes" rows="2" maxlength="1000"
                                  placeholder="Optional description"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Record</button>
                </div>
            </form>
        </div>
    </div>
</div>
