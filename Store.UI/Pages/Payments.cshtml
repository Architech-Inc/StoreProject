@page
@model PaymentsModel
@using StoreUI.Pages
@using Store.Models.Enums
@using Store.Models.DTOs.Payments
@{
    ViewData["Title"] = "Payments";

    string StatusBadge(string s) => s switch
    {
        "Pending"   => "badge-pending",
        "Completed" => "badge-completed",
        "Failed"    => "badge-failed",
        "TimedOut"  => "badge-timedout",
        _           => ""
    };

    string StatusLabel(string s) => s switch
    {
        "TimedOut" => "Timed Out",
        _          => s
    };
}

<div class="page-container">
    <h1 class="page-title">Mobile Money Payments</h1>

    @if (TempData["StatusMessage"] is string msg)
    {
        <div class="alert alert-info">@msg</div>
    }

    @* ── Settlement Summary ──────────────────────────────── *@
    <section class="card mb-4">
        <div class="card-header">
            <h2 class="card-title">Settlement Summary</h2>
            <form method="get" class="filter-form">
                <label>From <input type="date" name="from" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" /></label>
                <label>To <input type="date" name="to" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" /></label>
                <input type="hidden" name="status" value="@((int?)Model.StatusFilter)" />
                <input type="hidden" name="page" value="1" />
                <button type="submit" class="btn btn-sm btn-primary">Filter</button>
            </form>
        </div>
        @if (Model.Settlement is not null)
        {
            <div class="summary-cards">
                <div class="summary-card">
                    <span class="summary-label">Total Invoices</span>
                    <span class="summary-value">@Model.Settlement.TotalInvoices</span>
                </div>
                <div class="summary-card">
                    <span class="summary-label">Total Sales</span>
                    <span class="summary-value">@Model.Settlement.TotalSales.ToString("N2")</span>
                </div>
                <div class="summary-card">
                    <span class="summary-label">Pending MoMo</span>
                    <span class="summary-value">@Model.Settlement.PendingMobileMoneyTransactions</span>
                </div>
            </div>
            @if (Model.Settlement.ByChannel.Count > 0)
            {
                <table class="data-table mt-3">
                    <thead>
                        <tr>
                            <th>Channel</th>
                            <th>Invoices</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ch in Model.Settlement.ByChannel)
                        {
                            <tr>
                                <td>@ch.Channel</td>
                                <td>@ch.InvoiceCount</td>
                                <td>@ch.TotalAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else
        {
            <p class="text-muted px-3">No settlement data available for the selected period.</p>
        }
    </section>

    @* ── Transaction List ──────────────────────────────── *@
    <section class="card">
        <div class="card-header">
            <h2 class="card-title">Transactions</h2>
            <form method="get" class="filter-form">
                <input type="hidden" name="from" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="to" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="page" value="1" />
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    @foreach (MobileMoneyStatus s in Enum.GetValues<MobileMoneyStatus>())
                    {
                        <option value="@((int)s)" selected="@(Model.StatusFilter == s)">@StatusLabel(s.ToString())</option>
                    }
                </select>
                <button type="submit" class="btn btn-sm btn-primary">Filter</button>
            </form>
        </div>

        @if (Model.Transactions.Count == 0)
        {
            <p class="text-muted px-3 py-2">No transactions found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Invoice</th>
                            <th>Provider</th>
                            <th>Phone</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Provider Ref</th>
                            <th>Completed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.Transactions)
                        {
                            <tr>
                                <td>@tx.DateCreated.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td><code>@tx.InvoiceId.ToString()[..8]…</code></td>
                                <td>@tx.Provider</td>
                                <td>@tx.PhoneNumber</td>
                                <td>@tx.Amount.ToString("N2")</td>
                                <td><span class="badge @StatusBadge(tx.Status)">@StatusLabel(tx.Status)</span></td>
                                <td>@(tx.ProviderTransactionId ?? "—")</td>
                                <td>@(tx.CompletedAtUtc.HasValue ? tx.CompletedAtUtc.Value.ToLocalTime().ToString("dd MMM HH:mm") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?page=@(Model.CurrentPage - 1)&status=@((int?)Model.StatusFilter)&from=@Model.FromDate?.ToString("yyyy-MM-dd")&to=@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline">Previous</a>
                }
                <span class="page-info">Page @Model.CurrentPage</span>
                @if (Model.Transactions.Count == Model.PageSize)
                {
                    <a href="?page=@(Model.CurrentPage + 1)&status=@((int?)Model.StatusFilter)&from=@Model.FromDate?.ToString("yyyy-MM-dd")&to=@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline">Next</a>
                }
            </div>
        }
    </section>
</div>

<style>
    .badge-pending   { background: #fef3c7; color: #92400e; }
    .badge-completed { background: #d1fae5; color: #065f46; }
    .badge-failed    { background: #fee2e2; color: #991b1b; }
    .badge-timedout  { background: #f3f4f6; color: #374151; }
    .badge { padding: 2px 8px; border-radius: 9999px; font-size: .75rem; font-weight: 600; }
    .summary-cards { display: flex; gap: 1rem; padding: 1rem; flex-wrap: wrap; }
    .summary-card { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: .5rem; padding: .75rem 1.25rem; min-width: 150px; }
    .summary-label { display: block; font-size: .75rem; color: #6b7280; }
    .summary-value { display: block; font-size: 1.25rem; font-weight: 700; color: #111827; }
    .pagination { display: flex; align-items: center; gap: .5rem; padding: .75rem 1rem; }
    .page-info { font-size: .875rem; color: #6b7280; }
</style>
