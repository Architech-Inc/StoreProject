@page
@model StoreUI.Pages.CashVarianceModel
@using Store.Models.Enums
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Cash Variance";
    ViewData["ActivePage"] = "CashVariance";
}

@if (TempData["StatusMessage"] is string msg)
{
    var isError = msg.StartsWith("Error:", StringComparison.OrdinalIgnoreCase);
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Cash Variance</h4>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#recordModal">
        + Record Variance
    </button>
</div>

<!-- Filter bar -->
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetValues<CashVarianceStatus>())
            {
                <option value="@s" selected="@(Model.FilterStatus == s.ToString())">@s</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-secondary btn-sm" type="submit">Filter</button>
    </div>
</form>

<!-- Variance Table -->
<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Shift ID</th>
                <th>Expected</th>
                <th>Actual</th>
                <th>Variance</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Recorded By</th>
                <th>Reviewed By</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model.Variances)
            {
                var variance = v.ActualAmount - v.ExpectedAmount;
                <tr>
                    <td>@v.CashVarianceRecordId</td>
                    <td class="text-muted" style="font-size:.75rem;">@v.CashierShiftId.ToString()[..8]…</td>
                    <td>@v.ExpectedAmount.ToString("N2")</td>
                    <td>@v.ActualAmount.ToString("N2")</td>
                    <td class="@(variance < 0 ? "text-danger" : "text-success") fw-semibold">
                        @(variance >= 0 ? "+" : "")@variance.ToString("N2")
                    </td>
                    <td>@(v.ReasonCode ?? "—")</td>
                    <td>
                        <span class="badge @(v.Status switch {
                            "Pending" => "bg-warning text-dark",
                            "Reviewed" => "bg-success",
                            "Escalated" => "bg-danger",
                            _ => "bg-secondary" })">
                            @v.Status
                        </span>
                    </td>
                    <td>@v.RecordedByUser</td>
                    <td>@(v.ReviewedByUser ?? "—")</td>
                    <td>@v.DateCreated.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (v.Status == "Pending")
                        {
                            <button class="btn btn-outline-primary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#reviewModal"
                                    data-variance-id="@v.CashVarianceRecordId"
                                    data-notes="@v.Notes">
                                Review
                            </button>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Variances.Any())
            {
                <tr><td colspan="11" class="text-center text-muted py-3">No variance records found.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- ===== Record Variance Modal ===== -->
<div class="modal fade" id="recordModal" tabindex="-1" aria-labelledby="recordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Record">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="recordModalLabel">Record Cash Variance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Cashier Shift ID <span class="text-danger">*</span></label>
                        <input type="text" name="RecordShiftId" class="form-control form-control-sm"
                               placeholder="Shift GUID" required />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">Expected Amount</label>
                            <input type="number" name="RecordExpected" class="form-control form-control-sm"
                                   step="0.01" value="0.00" required />
                        </div>
                        <div class="col">
                            <label class="form-label">Actual Amount</label>
                            <input type="number" name="RecordActual" class="form-control form-control-sm"
                                   step="0.01" value="0.00" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason Code</label>
                        <input type="text" name="RecordReasonCode" class="form-control form-control-sm"
                               placeholder="e.g. COUNTING_ERROR" maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="RecordNotes" class="form-control form-control-sm" rows="2" maxlength="2000"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Record Variance</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ===== Review Modal ===== -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Review">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="reviewModalLabel">Review Variance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="ReviewVarianceId" id="reviewVarianceId" />
                    <div class="mb-3">
                        <label class="form-label">Decision <span class="text-danger">*</span></label>
                        <select name="ReviewStatus" class="form-select form-select-sm" required>
                            @foreach (var s in Model.ReviewableStatuses)
                            {
                                <option value="@((int)s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Review Notes</label>
                        <textarea name="ReviewNotes" class="form-control form-control-sm" rows="3" maxlength="2000"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit Review</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
const reviewModal = document.getElementById('reviewModal');
reviewModal.addEventListener('show.bs.modal', function (e) {
    const btn = e.relatedTarget;
    document.getElementById('reviewVarianceId').value = btn.getAttribute('data-variance-id');
});
</script>
}
