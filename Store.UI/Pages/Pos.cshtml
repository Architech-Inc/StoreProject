@page
@model StoreUI.Pages.PosModel
@using System.Text.Json
@{
    ViewData["Title"] = "POS Terminal";

    var catalogJson = JsonSerializer.Serialize(Model.CatalogItems.Select(i => new
    {
        itemId = i.ItemId,
        name = i.Name,
        barcode = i.Barcode,
        unitPrice = i.UnitPrice,
        inStock = i.InStock,
        categoryName = i.CategoryName,
        unit = i.UnitAbbreviation,
        discountPercentage = i.DiscountPercentage
    }));

    var customersJson = JsonSerializer.Serialize(Model.Customers.Select(c => new
    {
        customerId = c.CustomerId,
        fullName = c.FullName,
        primaryPhone = c.PrimaryPhone
    }));
}

@section Styles {
    <link rel="stylesheet" href="~/css/pos.css" asp-append-version="true" />
}

<div class="pos-shell">
    <partial name="Shared/_ModuleNav" />

    <header class="pos-topbar">
        <div>
            <h1>POS Terminal</h1>
            <p>Fast checkout flow for supermarket operations.</p>
        </div>
        <div class="pos-top-actions">
            <a class="btn btn-secondary" href="/Dashboard">Back to Dashboard</a>
            <form method="post" asp-page-handler="Logout">
                <button type="submit" class="btn btn-danger">Sign Out</button>
            </form>
        </div>
    </header>

    @if (Model.HasLoadError)
    {
        <div class="banner banner-error" role="alert">
            <strong>POS Load Error:</strong> @Model.LoadErrorMessage
        </div>
    }

    <div class="pos-grid">
        <section class="catalog-panel" id="catalog" aria-label="Product catalog">
            <div class="panel-head">
                <h2>Catalog</h2>
                <input id="catalogSearch" type="search" placeholder="Search products..." aria-label="Search products" />
            </div>

            <div class="scanner-row">
                <label for="barcodeInput">Barcode</label>
                <div class="scanner-input-wrap">
                    <input id="barcodeInput" type="text" placeholder="Scan or type barcode then press Enter" autocomplete="off" />
                    <button type="button" class="btn btn-primary" id="barcodeAddBtn">Add</button>
                </div>
            </div>

            <div id="catalogList" class="catalog-list"></div>
        </section>

        <section class="cart-panel" id="checkout" aria-label="Checkout cart">
            <div class="panel-head">
                <h2>Cart</h2>
                <div class="cart-head-actions">
                    <button type="button" class="btn btn-secondary" id="suspendSaleBtn">Suspend</button>
                    <button type="button" class="btn btn-warning" id="clearCartBtn">Clear</button>
                </div>
            </div>

            <div id="cartEmpty" class="cart-empty">No items in cart.</div>
            <table id="cartTable" class="cart-table" hidden>
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Price</th>
                        <th>Qty</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="cartBody"></tbody>
            </table>

            <div class="checkout-box">
                <div class="field-row">
                    <label for="customerSelect">Customer</label>
                    <select id="customerSelect">
                        <option value="">Walk-in Customer</option>
                    </select>
                </div>

                <div class="field-row">
                    <label for="paymentType">Payment Type</label>
                    <select id="paymentType">
                        <option value="0">Cash</option>
                        <option value="1">Card</option>
                        <option value="2">Bank Transfer</option>
                        <option value="3">Mobile Money</option>
                        <option value="4">Cheque</option>
                        <option value="5">Credit</option>
                    </select>
                </div>

                <div class="field-row">
                    <label for="amountTendered">Amount Tendered (XAF)</label>
                    <input id="amountTendered" type="number" min="0" step="0.01" value="0" />
                </div>

                <div class="field-row">
                    <label for="saleNotes">Notes</label>
                    <textarea id="saleNotes" rows="2" maxlength="300" placeholder="Optional note for this sale"></textarea>
                </div>

                <div class="totals">
                    <div><span>Subtotal</span><strong id="subtotalText">0</strong></div>
                    <div><span>Change</span><strong id="changeText">0</strong></div>
                </div>

                <div class="suspended-sales">
                    <label for="suspendedSaleSelect">Suspended Sales</label>
                    <div class="suspended-actions">
                        <select id="suspendedSaleSelect">
                            <option value="">No suspended sale</option>
                        </select>
                        <button type="button" class="btn btn-secondary" id="resumeSaleBtn">Resume</button>
                        <button type="button" class="btn btn-danger" id="deleteSuspendedBtn">Delete</button>
                    </div>
                </div>

                <form id="checkoutForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" id="checkoutBtn" class="btn btn-primary">Complete Checkout</button>
                </form>

                <div id="checkoutMessage" class="checkout-message" role="status" aria-live="polite"></div>
            </div>
        </section>
    </div>
</div>

<div id="receiptModal" class="receipt-modal" hidden>
    <div class="receipt-backdrop" data-close="receipt"></div>
    <div class="receipt-dialog" role="dialog" aria-modal="true" aria-labelledby="receiptTitle">
        <div class="receipt-head">
            <h3 id="receiptTitle">Receipt</h3>
            <button type="button" class="btn btn-secondary" id="receiptCloseBtn">Close</button>
        </div>
        <div id="receiptContent" class="receipt-content"></div>
        <div class="receipt-actions">
            <button type="button" class="btn btn-primary" id="receiptPrintBtn">Print</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const catalog = @Html.Raw(catalogJson);
    const customers = @Html.Raw(customersJson);

    const cart = new Map();
    const catalogList = document.getElementById('catalogList');
    const catalogSearch = document.getElementById('catalogSearch');
    const cartBody = document.getElementById('cartBody');
    const cartTable = document.getElementById('cartTable');
    const cartEmpty = document.getElementById('cartEmpty');
    const subtotalText = document.getElementById('subtotalText');
    const changeText = document.getElementById('changeText');
    const amountTenderedInput = document.getElementById('amountTendered');
    const customerSelect = document.getElementById('customerSelect');
    const checkoutForm = document.getElementById('checkoutForm');
    const checkoutBtn = document.getElementById('checkoutBtn');
    const paymentType = document.getElementById('paymentType');
    const saleNotes = document.getElementById('saleNotes');
    const checkoutMessage = document.getElementById('checkoutMessage');
    const clearCartBtn = document.getElementById('clearCartBtn');
    const barcodeInput = document.getElementById('barcodeInput');
    const barcodeAddBtn = document.getElementById('barcodeAddBtn');
    const suspendSaleBtn = document.getElementById('suspendSaleBtn');
    const suspendedSaleSelect = document.getElementById('suspendedSaleSelect');
    const resumeSaleBtn = document.getElementById('resumeSaleBtn');
    const deleteSuspendedBtn = document.getElementById('deleteSuspendedBtn');
    const receiptModal = document.getElementById('receiptModal');
    const receiptContent = document.getElementById('receiptContent');
    const receiptCloseBtn = document.getElementById('receiptCloseBtn');
    const receiptPrintBtn = document.getElementById('receiptPrintBtn');

    const suspendedSalesStorageKey = 'store-ui-pos-suspended-sales';

    function xaf(value) {
        return Number(value).toLocaleString('en-US', { maximumFractionDigits: 2 });
    }

    function normalizeBarcode(value) {
        return String(value ?? '').trim().toLowerCase();
    }

    function getSuspendedSales() {
        const raw = localStorage.getItem(suspendedSalesStorageKey);
        if (!raw) {
            return [];
        }

        try {
            const parsed = JSON.parse(raw);
            return Array.isArray(parsed) ? parsed : [];
        } catch {
            return [];
        }
    }

    function setSuspendedSales(sales) {
        localStorage.setItem(suspendedSalesStorageKey, JSON.stringify(sales));
    }

    function getEffectivePrice(item) {
        if (!item.discountPercentage || item.discountPercentage <= 0) {
            return Number(item.unitPrice);
        }

        const discount = Number(item.unitPrice) * (Number(item.discountPercentage) / 100);
        return Number(item.unitPrice) - discount;
    }

    function renderCatalog(filterText = '') {
        const q = filterText.trim().toLowerCase();
        const filtered = q.length === 0
            ? catalog
            : catalog.filter(i => i.name.toLowerCase().includes(q) || (i.categoryName ?? '').toLowerCase().includes(q));

        catalogList.innerHTML = '';

        if (filtered.length === 0) {
            catalogList.innerHTML = '<p class="catalog-empty">No matching products.</p>';
            return;
        }

        for (const item of filtered) {
            const card = document.createElement('article');
            card.className = 'catalog-item';
            const effectivePrice = getEffectivePrice(item);
            card.innerHTML = `
                <h3>${item.name}</h3>
                <p>${item.categoryName ?? 'Uncategorized'} ${item.unit ? `• ${item.unit}` : ''}</p>
                <div class="catalog-meta">
                    <strong>${xaf(effectivePrice)} XAF</strong>
                    <span>${item.inStock} in stock</span>
                </div>
                <button type="button" data-id="${item.itemId}">Add</button>
            `;

            card.querySelector('button').addEventListener('click', () => addToCart(item));
            catalogList.appendChild(card);
        }
    }

    function renderSuspendedSales() {
        const sales = getSuspendedSales();
        const previousValue = suspendedSaleSelect.value;
        suspendedSaleSelect.innerHTML = '<option value="">No suspended sale</option>';

        for (const sale of sales) {
            const option = document.createElement('option');
            option.value = sale.id;
            option.textContent = sale.label;
            suspendedSaleSelect.appendChild(option);
        }

        if (previousValue) {
            suspendedSaleSelect.value = previousValue;
        }
    }

    function addToCart(item) {
        const existing = cart.get(item.itemId);
        const currentQty = existing ? existing.quantity : 0;

        if (currentQty + 1 > item.inStock) {
            setMessage('Cannot exceed available stock.', true);
            return;
        }

        cart.set(item.itemId, {
            itemId: item.itemId,
            name: item.name,
            unitPrice: getEffectivePrice(item),
            maxStock: item.inStock,
            quantity: currentQty + 1
        });

        renderCart();
    }

    function setQuantity(itemId, quantity) {
        const entry = cart.get(itemId);
        if (!entry) {
            return;
        }

        if (quantity <= 0) {
            cart.delete(itemId);
            renderCart();
            return;
        }

        if (quantity > entry.maxStock) {
            setMessage(`Cannot exceed stock (${entry.maxStock}) for ${entry.name}.`, true);
            return;
        }

        entry.quantity = quantity;
        renderCart();
    }

    function removeItem(itemId) {
        cart.delete(itemId);
        renderCart();
    }

    function getSubtotal() {
        let total = 0;
        for (const entry of cart.values()) {
            total += entry.unitPrice * entry.quantity;
        }
        return total;
    }

    function renderCart() {
        cartBody.innerHTML = '';

        if (cart.size === 0) {
            cartTable.hidden = true;
            cartEmpty.hidden = false;
            subtotalText.textContent = '0';
            changeText.textContent = '0';
            return;
        }

        cartTable.hidden = false;
        cartEmpty.hidden = true;

        for (const entry of cart.values()) {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${entry.name}</td>
                <td>${xaf(entry.unitPrice)}</td>
                <td><input type="number" min="1" max="${entry.maxStock}" value="${entry.quantity}" data-qty="${entry.itemId}" /></td>
                <td>${xaf(entry.unitPrice * entry.quantity)}</td>
                <td><button type="button" class="danger" data-del="${entry.itemId}">Remove</button></td>
            `;
            cartBody.appendChild(tr);
        }

        for (const input of cartBody.querySelectorAll('[data-qty]')) {
            input.addEventListener('change', (e) => {
                const target = e.target;
                setQuantity(target.dataset.qty, Number(target.value));
            });
        }

        for (const button of cartBody.querySelectorAll('[data-del]')) {
            button.addEventListener('click', (e) => {
                const target = e.target;
                removeItem(target.dataset.del);
            });
        }

        const subtotal = getSubtotal();
        const tendered = Number(amountTenderedInput.value || '0');
        const change = Math.max(0, tendered - subtotal);

        subtotalText.textContent = `${xaf(subtotal)} XAF`;
        changeText.textContent = `${xaf(change)} XAF`;
    }

    function setMessage(message, isError = false) {
        checkoutMessage.textContent = message;
        checkoutMessage.className = isError ? 'checkout-message error' : 'checkout-message ok';
    }

    function showReceipt(checkoutResult, saleLines) {
        const createdAt = checkoutResult.createdAt
            ? new Date(checkoutResult.createdAt).toLocaleString()
            : new Date().toLocaleString();

        const lineItemsHtml = saleLines.map(line => `
            <tr>
                <td>${line.name}</td>
                <td>${line.quantity}</td>
                <td>${xaf(line.unitPrice)}</td>
                <td>${xaf(line.unitPrice * line.quantity)}</td>
            </tr>
        `).join('');

        receiptContent.innerHTML = `
            <div class="receipt-summary">
                <p><strong>Invoice:</strong> ${checkoutResult.invoiceId}</p>
                <p><strong>Date:</strong> ${createdAt}</p>
                <p><strong>Payment:</strong> ${checkoutResult.paymentType}</p>
                <p><strong>Total:</strong> ${xaf(checkoutResult.totalAmount)} XAF</p>
                <p><strong>Tendered:</strong> ${xaf(checkoutResult.amountTendered)} XAF</p>
                <p><strong>Change:</strong> ${xaf(checkoutResult.changeGiven)} XAF</p>
            </div>
            <table class="receipt-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Unit</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    ${lineItemsHtml}
                </tbody>
            </table>
        `;

        receiptModal.hidden = false;
    }

    function closeReceipt() {
        receiptModal.hidden = true;
    }

    function suspendCurrentSale() {
        if (cart.size === 0) {
            setMessage('Cart is empty, nothing to suspend.', true);
            return;
        }

        const suspendedSales = getSuspendedSales();
        const saleId = crypto.randomUUID();
        const snapshot = {
            id: saleId,
            label: `Sale ${new Date().toLocaleTimeString()}`,
            customerId: customerSelect.value || '',
            paymentType: paymentType.value,
            amountTendered: amountTenderedInput.value,
            notes: saleNotes.value || '',
            lines: Array.from(cart.values())
        };

        suspendedSales.unshift(snapshot);
        setSuspendedSales(suspendedSales);
        renderSuspendedSales();

        cart.clear();
        amountTenderedInput.value = '0';
        saleNotes.value = '';
        customerSelect.value = '';
        paymentType.value = '0';
        renderCart();
        setMessage('Sale suspended. You can resume it from the list.');
    }

    function restoreSuspendedSale(removeAfterRestore) {
        const suspendedId = suspendedSaleSelect.value;
        if (!suspendedId) {
            setMessage('Select a suspended sale first.', true);
            return;
        }

        const suspendedSales = getSuspendedSales();
        const snapshot = suspendedSales.find(s => s.id === suspendedId);
        if (!snapshot) {
            setMessage('Suspended sale not found.', true);
            renderSuspendedSales();
            return;
        }

        if (removeAfterRestore) {
            setSuspendedSales(suspendedSales.filter(s => s.id !== suspendedId));
        }

        cart.clear();
        for (const line of snapshot.lines ?? []) {
            const matchedItem = catalog.find(i => i.itemId === line.itemId);
            const maxStock = matchedItem ? matchedItem.inStock : line.maxStock;
            const safeQty = Math.min(line.quantity ?? 0, maxStock ?? 0);

            if (!matchedItem || safeQty <= 0) {
                continue;
            }

            cart.set(matchedItem.itemId, {
                itemId: matchedItem.itemId,
                name: matchedItem.name,
                unitPrice: getEffectivePrice(matchedItem),
                maxStock: matchedItem.inStock,
                quantity: safeQty
            });
        }

        customerSelect.value = snapshot.customerId || '';
        paymentType.value = snapshot.paymentType || '0';
        amountTenderedInput.value = snapshot.amountTendered || '0';
        saleNotes.value = snapshot.notes || '';

        renderSuspendedSales();
        renderCart();
        setMessage(removeAfterRestore
            ? 'Suspended sale resumed into cart.'
            : 'Suspended sale preview restored to cart.');
    }

    function deleteSuspendedSale() {
        const suspendedId = suspendedSaleSelect.value;
        if (!suspendedId) {
            setMessage('Select a suspended sale to delete.', true);
            return;
        }

        const suspendedSales = getSuspendedSales();
        setSuspendedSales(suspendedSales.filter(s => s.id !== suspendedId));
        renderSuspendedSales();
        setMessage('Suspended sale deleted.');
    }

    function addByBarcode() {
        const scanValue = normalizeBarcode(barcodeInput.value);
        if (!scanValue) {
            setMessage('Scan or type a barcode first.', true);
            return;
        }

        const item = catalog.find(i => normalizeBarcode(i.barcode) === scanValue);
        if (!item) {
            setMessage(`No catalog item found for barcode "${barcodeInput.value}".`, true);
            return;
        }

        addToCart(item);
        barcodeInput.value = '';
        barcodeInput.focus();
        setMessage(`${item.name} added to cart.`);
    }

    async function checkoutAsync() {
        if (cart.size === 0) {
            setMessage('Add at least one item before checkout.', true);
            return;
        }

        const subtotal = getSubtotal();
        const tendered = Number(amountTenderedInput.value || '0');
        if (tendered < subtotal) {
            setMessage('Amount tendered must cover subtotal.', true);
            return;
        }

        const payload = {
            customerId: customerSelect.value || null,
            paymentType: Number(paymentType.value),
            amountTendered: tendered,
            notes: saleNotes.value || null,
            lines: Array.from(cart.values()).map(v => ({ itemId: v.itemId, quantity: v.quantity }))
        };
        const saleLines = Array.from(cart.values());

        const antiforgery = checkoutForm.querySelector('input[name="__RequestVerificationToken"]')?.value;

        checkoutBtn.disabled = true;
        setMessage('Processing checkout...');

        try {
            const response = await fetch('?handler=Checkout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiforgery
                },
                body: JSON.stringify(payload)
            });

            const body = await response.json();
            if (!response.ok || !body.success) {
                setMessage(body.message ?? 'Checkout failed.', true);
                return;
            }

            cart.clear();
            amountTenderedInput.value = '0';
            saleNotes.value = '';
            renderCart();
            setMessage(`Invoice ${body.invoiceId} completed. Change: ${xaf(body.changeGiven)} XAF`);
            showReceipt(body, saleLines);
            renderCatalog(catalogSearch.value);
        } catch {
            setMessage('Unable to reach server for checkout.', true);
        } finally {
            checkoutBtn.disabled = false;
        }
    }

    function seedCustomers() {
        for (const c of customers) {
            const option = document.createElement('option');
            option.value = c.customerId;
            option.textContent = c.primaryPhone ? `${c.fullName} (${c.primaryPhone})` : c.fullName;
            customerSelect.appendChild(option);
        }
    }

    catalogSearch.addEventListener('input', () => renderCatalog(catalogSearch.value));
    amountTenderedInput.addEventListener('input', renderCart);
    barcodeAddBtn.addEventListener('click', addByBarcode);
    barcodeInput.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter') {
            return;
        }

        e.preventDefault();
        addByBarcode();
    });
    suspendSaleBtn.addEventListener('click', suspendCurrentSale);
    resumeSaleBtn.addEventListener('click', () => restoreSuspendedSale(true));
    deleteSuspendedBtn.addEventListener('click', deleteSuspendedSale);
    receiptCloseBtn.addEventListener('click', closeReceipt);
    receiptPrintBtn.addEventListener('click', () => window.print());
    receiptModal.addEventListener('click', (e) => {
        const target = e.target;
        if (target.dataset.close === 'receipt') {
            closeReceipt();
        }
    });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !receiptModal.hidden) {
            closeReceipt();
        }
    });
    clearCartBtn.addEventListener('click', () => {
        cart.clear();
        renderCart();
    });
    checkoutForm.addEventListener('submit', (e) => {
        e.preventDefault();
        checkoutAsync();
    });

    seedCustomers();
    renderSuspendedSales();
    renderCatalog();
    renderCart();
})();
</script>
}
